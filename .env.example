# ── LACA TV Environment Variables ──────────────
# Copy this to .env and fill in your values

# Supabase (for production DB + video storage)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# API-Football (for real live scores)
REACT_APP_FOOTBALL_API_KEY=your-key-from-api-football.com

# Admin subdomain (set in your hosting platform)
# admin.yourdomain.com → routes to AdminPanel automatically
